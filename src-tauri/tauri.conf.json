{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Countdown Manager",
    "version": "0.1.0",
    "identifier": "com.ticktock.countdown-manager",
    "build": {
        "frontendDist": "../src"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "label": "main",
                "title": "Countdown Manager",
                "width": 1000,
                "height": 680,
                "minWidth": 800,
                "minHeight": 560,
                "resizable": true,
                "fullscreen": false,
                "center": true,
                "decorations": true,
                "transparent": false,
                "visible": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}